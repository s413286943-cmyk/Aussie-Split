{
  "name": "aussie-split-bill",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "node node_modules/next/dist/bin/next dev --webpack",
    "build": "node node_modules/next/dist/bin/next build --webpack",
    "start": "node node_modules/next/dist/bin/next start",
    "itinerary:seed": "node scripts/create-itinerary-workbook.mjs",
    "itinerary:import": "node scripts/import-itinerary.mjs",
    "ledger:snapshot": "node scripts/export-ledger-snapshot.mjs",
    "lint": "node node_modules/eslint/bin/eslint.js",
    "test": "node --conditions=react-server --test --test-concurrency=1 tests/*.test.mjs",
    "test:e2e": "node e2e/run-tests.mjs --project=local-chrome",
    "test:e2e:production": "E2E_PRODUCTION_SMOKE=1 E2E_SKIP_WEB_SERVER=1 node e2e/run-tests.mjs --project=production-smoke"
  },
  "dependencies": {
    "gsap": "^3.15.0",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "server-only": "0.0.1",
    "tus-js-client": "4.3.1"
  },
  "devDependencies": {
    "@eslint-community/eslint-utils": "^4.9.1",
    "@types/node": "24.13.3",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "fake-indexeddb": "6.2.5",
    "playwright": "^1.61.1",
    "typescript": "^5"
  },
  "overrides": {
    "postcss": "8.5.16"
  }
}
